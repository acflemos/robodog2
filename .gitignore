# ROS2 workspace (caso o repo seja clonado dentro de um workspace)
build/
install/
log/
.colcon_install_layout

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/
*.so

# Mapas gerados em runtime — ignorados por padrão; aprovar com: git add -f maps/<nome>.pgm maps/<nome>.yaml
maps/*.pgm
maps/*.yaml
# Mapas aprovados do ambiente de produção (versionados)
!maps/rbd_mapa_vazio.yaml
!maps/rbd_mapa_vazio.pgm
!maps/rbd_mapa_moveis.yaml
!maps/rbd_mapa_moveis.pgm

# VS Code
.vscode/
*.code-workspace

# Sistema
.DS_Store
Thumbs.db
*~
*.swp
*.swo

# Logs e dados temporários
*.log
*.bag
*.db3
