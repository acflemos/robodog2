<?xml version="1.0"?>
<!--
  rbd_X3_sim.urdf.xacro — URDF de simulação Gazebo do robodog2 (ROSMASTER X3, ROS2)
  ===================================================================================
  Adaptado de yahboomcar_X3_sim.urdf.xacro (ROS1/robodog1).

  Alterações em relação ao original ROS1:
    1. Caminhos das malhas: package://robodog1 → package://robodog2
       Sufixo _X3 adicionado nos ficheiros da pasta mecanum/ (ex: base_link_X3.STL).
    2. Plugin planar_move: parâmetros renomeados para convenção ROS2 (snake_case).
    3. Plugin LiDAR: libgazebo_ros_laser.so → libgazebo_ros_ray_sensor.so;
       usa <ros><remapping>~/out:=scan</remapping></ros> e <output_type>.
    4. Plugin IMU: substitui <topicName> por <ros><remapping>~/out:=imu/data_raw</remapping></ros>;
       tópico renomeado para /imu/data_raw (entrada do imu_filter_madgwick).

  Plugins Gazebo incluídos:
    1. libgazebo_ros_planar_move.so  — movimento omnidirecional (mecanum virtual)
         Subscreve /cmd_vel; publica /odom e TF odom → base_footprint.
    2. libgazebo_ros_ray_sensor.so   — sensor LiDAR 360° (LDROBOT LD14 simulado)
         Publica /scan (sensor_msgs/LaserScan) no frame laser_link.
    3. libgazebo_ros_imu_sensor.so   — IMU simulado
         Publica /imu/data_raw (sensor_msgs/Imu) no frame imu_link.

  TF publicados (plugin planar_move + robot_state_publisher):
    odom → base_footprint → base_link → {rodas, laser_link, camera_link, imu_link}

  Nós necessários em runtime:
    robot_state_publisher   — TF de joints a partir deste URDF
    imu_filter_madgwick     — /imu/data_raw → /imu/data (orientação fundida)
    Gazebo Classic          — motor de simulação
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="yahboomcar">

  <!-- ===================================================================== -->
  <!-- GEOMETRIA DO ROBÔ                                                      -->
  <!-- ===================================================================== -->

  <link name="base_footprint"/>
  <link name="imu_link"/>

  <link name="base_link">
    <inertial>
      <origin xyz="0.00498197982182523 5.70233829969297E-05 -0.0121008098068578" rpy="0 0 0"/>
      <mass value="0.486218814966626"/>
      <inertia ixx="0.00196277727666921" ixy="2.50447049446755E-07" ixz="0.000140534767811098"
               iyy="0.00457256033711368" iyz="2.68618064993882E-07"  izz="0.00493927269870476"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robodog2/meshes/mecanum/base_link_X3.STL"/>
      </geometry>
      <material name="Green"><color rgba="0 0.7 0 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.25 0.20 0.08"/>
      </geometry>
    </collision>
  </link>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0.0 0.0 0.0815" rpy="0 0 0"/>
  </joint>

  <joint name="base_imu" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="-0.06 0.01 0.01" rpy="0 3.1415 1.5707"/>
  </joint>

  <!-- Roda dianteira direita -->
  <link name="front_right_wheel">
    <inertial>
      <origin xyz="1.9051E-06 -2.3183E-07 -0.00064079" rpy="0 0 0"/>
      <mass value="0.051532"/>
      <inertia ixx="1.4595E-05" ixy="-4.3975E-10" ixz="4.415E-10"
               iyy="1.4594E-05" iyz="-1.7476E-09" izz="2.4264E-05"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robodog2/meshes/mecanum/front_right_wheel_X3.STL"/>
      </geometry>
      <material name="LightGray"><color rgba="0.7 0.7 0.7 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.033"/>
      </geometry>
    </collision>
  </link>
  <joint name="front_right_joint" type="continuous">
    <origin xyz="0.08 -0.0845 -0.0389" rpy="-1.5703 0 3.14159"/>
    <parent link="base_link"/>
    <child link="front_right_wheel"/>
    <axis xyz="0 0 -1" rpy="0 0 0"/>
    <limit effort="100" velocity="1"/>
  </joint>

  <!-- Roda dianteira esquerda -->
  <link name="front_left_wheel">
    <inertial>
      <origin xyz="2.3728E-06 -9.4228E-07 0.00064068" rpy="0 0 0"/>
      <mass value="0.051543"/>
      <inertia ixx="1.4597E-05" ixy="-4.7945E-10" ixz="-2.4786E-10"
               iyy="1.4598E-05" iyz="1.7972E-09"  izz="2.4267E-05"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robodog2/meshes/mecanum/front_left_wheel_X3.STL"/>
      </geometry>
      <material name="LightGray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.033"/>
      </geometry>
    </collision>
  </link>
  <joint name="front_left_joint" type="continuous">
    <origin xyz="0.08 0.084492 -0.0389" rpy="1.5703 0 0"/>
    <parent link="base_link"/>
    <child link="front_left_wheel"/>
    <axis xyz="0 0 1" rpy="0 0 0"/>
    <limit effort="100" velocity="1"/>
  </joint>

  <!-- Roda traseira direita -->
  <link name="back_right_wheel">
    <inertial>
      <origin xyz="-1.75924169923403E-06 1.28388821071107E-06 -0.000590549296238266" rpy="0 0 0"/>
      <mass value="0.051540174053366"/>
      <inertia ixx="1.45974152250002E-05" ixy="1.94850559178397E-10"  ixz="-1.61846387282284E-09"
               iyy="1.4596501955693E-05"  iyz="-6.27904057423818E-10" izz="2.42663091380451E-05"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robodog2/meshes/mecanum/back_right_wheel_X3.STL"/>
      </geometry>
      <material name="LightGray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.033"/>
      </geometry>
    </collision>
  </link>
  <joint name="back_right_joint" type="continuous">
    <origin xyz="-0.08 -0.0845 -0.03946" rpy="-1.57 0 3.14159"/>
    <parent link="base_link"/>
    <child link="back_right_wheel"/>
    <axis xyz="0 0 -1" rpy="0 0 0"/>
    <limit effort="100" velocity="1"/>
  </joint>

  <!-- Roda traseira esquerda -->
  <link name="back_left_wheel">
    <inertial>
      <origin xyz="-4.01213085227115E-07 2.04910264598596E-06 0.000590775697051377" rpy="0 0 0"/>
      <mass value="0.0515309299357028"/>
      <inertia ixx="1.45942986129926E-05" ixy="-3.19787215398093E-10" ixz="1.74943062058915E-09"
               iyy="1.45948727598913E-05" iyz="1.61769812110049E-10"  izz="2.4263683888153E-05"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robodog2/meshes/mecanum/back_left_wheel_X3.STL"/>
      </geometry>
      <material name="LightGray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.033"/>
      </geometry>
    </collision>
  </link>
  <joint name="back_left_joint" type="continuous">
    <origin xyz="-0.08 0.084492 -0.03954" rpy="1.5703 0 0"/>
    <parent link="base_link"/>
    <child link="back_left_wheel"/>
    <axis xyz="0 0 1" rpy="0 0 0"/>
    <limit effort="100" velocity="1"/>
  </joint>

  <!-- Sensor LiDAR -->
  <link name="laser_link">
    <inertial>
      <origin xyz="-0.0176558922685589 0.000671805271544437 0.0219302095894866" rpy="0 0 0"/>
      <mass value="0.0483909504209895"/>
      <inertia ixx="1.58456966399128E-05" ixy="-4.23913983850005E-07" ixz="-2.09597897904374E-07"
               iyy="3.89262522903605E-05" iyz="3.24809725932687E-07"  izz="4.86230801106223E-05"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robodog2/meshes/sensor/laser_link.STL"/>
      </geometry>
      <material name="LightGray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.035"/>
      </geometry>
    </collision>
  </link>
  <joint name="laser_joint" type="fixed">
    <origin xyz="0.0435 5.25826986680105E-05 0.11" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="laser_link"/>
  </joint>

  <!-- Câmera (massa zero — apenas visual) -->
  <link name="camera_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robodog2/meshes/sensor/camera_link.STL"/>
      </geometry>
      <material name="LightGray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.025 0.050 0.020"/>
      </geometry>
    </collision>
  </link>
  <joint name="camera_joint" type="fixed">
    <origin xyz="0.057105 1.7948E-05 0.03755" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="camera_link"/>
  </joint>

  <!-- ===================================================================== -->
  <!-- PLUGINS GAZEBO (Gazebo Harmonic / Ignition Gazebo 6)                   -->
  <!-- ===================================================================== -->

  <!-- Cores Gazebo -->
  <gazebo reference="base_link"><material>Gazebo/Green</material></gazebo>
  <!-- Fricção anisotrópica para simulação de rodas mecanum.
       mu=1.0 na direção de tração (fdir1), mu2=0.0 na direção livre do rolo.
       fdir1 calculado no frame do link a partir da diagonal no frame do chassi:
         FL/BL chassis [1,±1,0] → link Rx(+π/2)  → FL:[1,0,-1]  BL:[1,0,1]
         FR/BR chassis [1,±1,0] → link Rz(π)Rx(-π/2) → FR:[-1,0,-1] BR:[-1,0,1] -->
  <gazebo reference="front_right_wheel">
    <material>Gazebo/DarkGrey</material>
    <mu>1.0</mu>
    <mu2>0.0</mu2>
    <fdir1>-1 0 -1</fdir1>
  </gazebo>
  <gazebo reference="front_left_wheel">
    <material>Gazebo/DarkGrey</material>
    <mu>1.0</mu>
    <mu2>0.0</mu2>
    <fdir1>1 0 -1</fdir1>
  </gazebo>
  <gazebo reference="back_right_wheel">
    <material>Gazebo/DarkGrey</material>
    <mu>1.0</mu>
    <mu2>0.0</mu2>
    <fdir1>-1 0 1</fdir1>
  </gazebo>
  <gazebo reference="back_left_wheel">
    <material>Gazebo/DarkGrey</material>
    <mu>1.0</mu>
    <mu2>0.0</mu2>
    <fdir1>1 0 1</fdir1>
  </gazebo>
  <gazebo reference="laser_link"><material>Gazebo/FlatBlack</material></gazebo>

  <!--
    Controlo cinemático directo — equivalente ao libgazebo_ros_planar_move do ROS1.
    Aplica linear.x / linear.y / angular.z directamente ao corpo do modelo,
    sem depender da física de contacto das rodas.
    Tópico gz subscrito: /model/rosmaster_x3/cmd_vel (configurado no bridge YAML).
  -->
  <gazebo>
    <plugin filename="gz-sim-velocity-control-system"
            name="gz::sim::systems::VelocityControl">
    </plugin>
  </gazebo>

  <!-- Publica /odom e TF odom→base_footprint observando o movimento real do modelo. -->
  <gazebo>
    <plugin filename="ignition-gazebo-odometry-publisher-system"
            name="ignition::gazebo::systems::OdometryPublisher">
      <odom_frame>odom</odom_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
      <odom_topic>odom</odom_topic>
      <tf_topic>tf</tf_topic>
      <odom_publish_frequency>10</odom_publish_frequency>
      <dimensions>2</dimensions>
    </plugin>
  </gazebo>

  <!-- Publica /joint_states das 4 rodas -->
  <gazebo>
    <plugin filename="ignition-gazebo-joint-state-publisher-system"
            name="ignition::gazebo::systems::JointStatePublisher">
      <topic>joint_states</topic>
      <joint_name>front_left_joint</joint_name>
      <joint_name>front_right_joint</joint_name>
      <joint_name>back_left_joint</joint_name>
      <joint_name>back_right_joint</joint_name>
    </plugin>
  </gazebo>

  <!--
    LiDAR 360° nativo do Gazebo Harmonic (gpu_lidar).
    Publica em /scan via bridge YAML (rbd_x3_bridge.yaml).
  -->
  <gazebo reference="laser_link">
    <sensor name="lds_lfcd_sensor" type="gpu_lidar">
      <pose>0 0 0 0 0 0</pose>
      <update_rate>6</update_rate>
      <topic>scan</topic>
      <gz_frame_id>laser_link</gz_frame_id>
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>0.0</min_angle>
            <max_angle>6.28318530718</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.12</min>
          <max>12.0</max>
          <resolution>0.015</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </lidar>
    </sensor>
  </gazebo>

  <!-- IMU desactivado — tag <gz_frame_id> é Harmonic-only; causa falha silenciosa no Fortress v6.
       imu_link mantido como link estrutural para compatibilidade com hardware real.
       AMCL/Nav2 em simulação não necessita de IMU. -->

</robot>
