<?xml version="1.0"?>
<!--
  yahboomcar_X3_sim.urdf.xacro — URDF de simulação do ROSMASTER X3 para o robodog1
  ===================================================================================
  Arquivo autônomo que combina a geometria do X3 com plugins Gazebo para simulação.

  Origem da geometria:
    Baseado em yahboomcar_description/urdf/yahboomcar_X3.urdf (gerado pelo SolidWorks).
    A estrutura de links/joints é idêntica ao URDF compilado — sem namespace.

  Plugins Gazebo incluídos:
    1. libgazebo_ros_planar_move.so  — movimento omnidirecional (mecanum virtual)
         Subscreve /cmd_vel (geometry_msgs/Twist) com componentes x, y, theta.
         Publica /odom (nav_msgs/Odometry) e TF odom → base_footprint.
    2. libgazebo_ros_laser.so        — sensor LiDAR 360°
         Publica /scan (sensor_msgs/LaserScan) no frame laser_link.
         Configurado para LDROBOT LD14 (0.1–12 m, 360°, 6 Hz).
    3. libgazebo_ros_imu_sensor.so   — IMU
         Publica /imu (sensor_msgs/Imu) no frame imu_link.

  Frames TF publicados (pelo planar_move plugin + robot_state_publisher):
    map → odom → base_footprint → base_link → {rodas, laser_link, camera_link, imu_link}

  Dependências em tempo de execução:
    package://robodog1/meshes/  — malhas STL do robô
    robot_state_publisher                     — publica TF dos joints
    move_base com params x3/                  — DWA com vy_samples: 6
    AMCL com odom_model_type: omni            — localização para mecanum

  Uso no launch file (param robot_description via xacro):
    rosrun xacro xacro $(find robodog1)/urdf/yahboomcar_X3_sim.urdf.xacro
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="yahboomcar">

  <!-- ===================================================================== -->
  <!-- GEOMETRIA DO ROBÔ (baseada em yahboomcar_X3.urdf)                     -->
  <!-- ===================================================================== -->

  <link name="base_footprint"/>
  <link name="imu_link"/>

  <link name="base_link">
    <inertial>
      <origin xyz="0.00498197982182523 5.70233829969297E-05 -0.0121008098068578" rpy="0 0 0"/>
      <mass value="0.486218814966626"/>
      <inertia ixx="0.00196277727666921" ixy="2.50447049446755E-07" ixz="0.000140534767811098"
               iyy="0.00457256033711368" iyz="2.68618064993882E-07"  izz="0.00493927269870476"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robodog1/meshes/mecanum/base_link.STL"/>
      </geometry>
      <material name="Green"><color rgba="0 0.7 0 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robodog1/meshes/mecanum/base_link.STL"/>
      </geometry>
    </collision>
  </link>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0.0 0.0 0.0815" rpy="0 0 0"/>
  </joint>

  <joint name="base_imu" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="-0.06 0.01 0.01" rpy="0 3.1415 1.5707"/>
  </joint>

  <!-- Roda dianteira direita -->
  <link name="front_right_wheel">
    <inertial>
      <origin xyz="1.9051E-06 -2.3183E-07 -0.00064079" rpy="0 0 0"/>
      <mass value="0.051532"/>
      <inertia ixx="1.4595E-05" ixy="-4.3975E-10" ixz="4.415E-10"
               iyy="1.4594E-05" iyz="-1.7476E-09" izz="2.4264E-05"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robodog1/meshes/mecanum/front_right_wheel.STL"/>
      </geometry>
      <material name="LightGray"><color rgba="0.7 0.7 0.7 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robodog1/meshes/mecanum/front_right_wheel.STL"/>
      </geometry>
    </collision>
  </link>
  <joint name="front_right_joint" type="continuous">
    <origin xyz="0.08 -0.0845 -0.0389" rpy="-1.5703 0 3.14159"/>
    <parent link="base_link"/>
    <child link="front_right_wheel"/>
    <axis xyz="0 0 1" rpy="0 0 0"/>
    <limit effort="100" velocity="1"/>
  </joint>

  <!-- Roda dianteira esquerda -->
  <link name="front_left_wheel">
    <inertial>
      <origin xyz="2.3728E-06 -9.4228E-07 0.00064068" rpy="0 0 0"/>
      <mass value="0.051543"/>
      <inertia ixx="1.4597E-05" ixy="-4.7945E-10" ixz="-2.4786E-10"
               iyy="1.4598E-05" iyz="1.7972E-09"  izz="2.4267E-05"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robodog1/meshes/mecanum/front_left_wheel.STL"/>
      </geometry>
      <material name="LightGray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robodog1/meshes/mecanum/front_left_wheel.STL"/>
      </geometry>
    </collision>
  </link>
  <joint name="front_left_joint" type="continuous">
    <origin xyz="0.08 0.084492 -0.0389" rpy="1.5703 0 0"/>
    <parent link="base_link"/>
    <child link="front_left_wheel"/>
    <axis xyz="0 0 1" rpy="0 0 0"/>
    <limit effort="100" velocity="1"/>
  </joint>

  <!-- Roda traseira direita -->
  <link name="back_right_wheel">
    <inertial>
      <origin xyz="-1.75924169923403E-06 1.28388821071107E-06 -0.000590549296238266" rpy="0 0 0"/>
      <mass value="0.051540174053366"/>
      <inertia ixx="1.45974152250002E-05" ixy="1.94850559178397E-10"  ixz="-1.61846387282284E-09"
               iyy="1.4596501955693E-05"  iyz="-6.27904057423818E-10" izz="2.42663091380451E-05"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robodog1/meshes/mecanum/back_right_wheel.STL"/>
      </geometry>
      <material name="LightGray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robodog1/meshes/mecanum/back_right_wheel.STL"/>
      </geometry>
    </collision>
  </link>
  <joint name="back_right_joint" type="continuous">
    <origin xyz="-0.08 -0.0845 -0.03946" rpy="-1.57 0 3.14159"/>
    <parent link="base_link"/>
    <child link="back_right_wheel"/>
    <axis xyz="0 0 1" rpy="0 0 0"/>
    <limit effort="100" velocity="1"/>
  </joint>

  <!-- Roda traseira esquerda -->
  <link name="back_left_wheel">
    <inertial>
      <origin xyz="-4.01213085227115E-07 2.04910264598596E-06 0.000590775697051377" rpy="0 0 0"/>
      <mass value="0.0515309299357028"/>
      <inertia ixx="1.45942986129926E-05" ixy="-3.19787215398093E-10" ixz="1.74943062058915E-09"
               iyy="1.45948727598913E-05" iyz="1.61769812110049E-10"  izz="2.4263683888153E-05"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robodog1/meshes/mecanum/back_left_wheel.STL"/>
      </geometry>
      <material name="LightGray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robodog1/meshes/mecanum/back_left_wheel.STL"/>
      </geometry>
    </collision>
  </link>
  <joint name="back_left_joint" type="continuous">
    <origin xyz="-0.08 0.084492 -0.03954" rpy="1.5703 0 0"/>
    <parent link="base_link"/>
    <child link="back_left_wheel"/>
    <axis xyz="0 0 1" rpy="0 0 0"/>
    <limit effort="100" velocity="1"/>
  </joint>

  <!-- Sensor LiDAR -->
  <link name="laser_link">
    <inertial>
      <origin xyz="-0.0176558922685589 0.000671805271544437 0.0219302095894866" rpy="0 0 0"/>
      <mass value="0.0483909504209895"/>
      <inertia ixx="1.58456966399128E-05" ixy="-4.23913983850005E-07" ixz="-2.09597897904374E-07"
               iyy="3.89262522903605E-05" iyz="3.24809725932687E-07"  izz="4.86230801106223E-05"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robodog1/meshes/sensor/laser_link.STL"/>
      </geometry>
      <material name="LightGray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robodog1/meshes/sensor/laser_link.STL"/>
      </geometry>
    </collision>
  </link>
  <joint name="laser_joint" type="fixed">
    <origin xyz="0.0435 5.25826986680105E-05 0.11" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="laser_link"/>
  </joint>

  <!-- Câmera (massa zero — apenas visual) -->
  <link name="camera_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0"/>
      <inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robodog1/meshes/sensor/camera_link.STL"/>
      </geometry>
      <material name="LightGray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robodog1/meshes/sensor/camera_link.STL"/>
      </geometry>
    </collision>
  </link>
  <joint name="camera_joint" type="fixed">
    <origin xyz="0.057105 1.7948E-05 0.03755" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="camera_link"/>
  </joint>

  <!-- ===================================================================== -->
  <!-- PLUGINS GAZEBO                                                         -->
  <!-- ===================================================================== -->

  <!-- Cores Gazebo -->
  <gazebo reference="base_link"><material>Gazebo/Green</material></gazebo>
  <gazebo reference="front_right_wheel"><material>Gazebo/DarkGrey</material></gazebo>
  <gazebo reference="front_left_wheel"><material>Gazebo/DarkGrey</material></gazebo>
  <gazebo reference="back_right_wheel"><material>Gazebo/DarkGrey</material></gazebo>
  <gazebo reference="back_left_wheel"><material>Gazebo/DarkGrey</material></gazebo>
  <gazebo reference="laser_link"><material>Gazebo/FlatBlack</material></gazebo>

  <!--
    Plugin de movimento omnidirecional — substitui o Mcnamu_driver.py (hardware real).
    Recebe /cmd_vel com x (frente/trás), y (lateral) e angular.z (rotação).
    Publica /odom e TF odom → base_footprint.
    Nota: simula cinemática holonômica pura, sem física real das rodas mecanum.
  -->
  <gazebo>
    <plugin name="planar_move_controller" filename="libgazebo_ros_planar_move.so">
      <commandTopic>cmd_vel</commandTopic>
      <odometryTopic>odom</odometryTopic>
      <odometryFrame>odom</odometryFrame>
      <odometryRate>20.0</odometryRate>
      <robotBaseFrame>base_footprint</robotBaseFrame>
    </plugin>
  </gazebo>

  <!--
    Plugin do sensor LiDAR — LDROBOT LD14 360°.
    Publica /scan (sensor_msgs/LaserScan) no frame laser_link.
    O costmap_common_params.yaml usa sensor_frame: laser_link para este frame.
  -->
  <gazebo reference="laser_link">
    <sensor type="ray" name="lds_lfcd_sensor">
      <pose>0 0 0 0 0 0</pose>
      <visualize>false</visualize>
      <update_rate>6</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>0.0</min_angle>
            <max_angle>6.28318530718</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.12</min>
          <max>12.0</max>
          <resolution>0.015</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      <plugin name="gazebo_ros_laser" filename="libgazebo_ros_laser.so">
        <topicName>scan</topicName>
        <frameName>laser_link</frameName>
      </plugin>
    </sensor>
  </gazebo>

  <!--
    Plugin IMU — ICM20948 simulado.
    Publica /imu (sensor_msgs/Imu) no frame imu_link.
    Opcional para navegação básica (AMCL usa apenas /scan e /odom).
  -->
  <gazebo reference="imu_link">
    <gravity>true</gravity>
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <visualize>false</visualize>
      <plugin filename="libgazebo_ros_imu_sensor.so" name="imu_plugin">
        <topicName>imu</topicName>
        <bodyName>imu_link</bodyName>
        <updateRateHZ>100.0</updateRateHZ>
        <gaussianNoise>0.0</gaussianNoise>
        <xyzOffset>0 0 0</xyzOffset>
        <rpyOffset>0 0 0</rpyOffset>
        <frameName>imu_link</frameName>
        <initialOrientationAsReference>false</initialOrientationAsReference>
      </plugin>
      <pose>0 0 0 0 0 0</pose>
    </sensor>
  </gazebo>

</robot>
